    private Task HandleScheduleUpdated(GanttScheduleUpdate update)
    {
        var updates = update.CascadedUpdates
            .Append(update.PrimaryUpdate)
            .ToDictionary(item => item.ItemId, item => item.Item);

        TaskGroups = TaskGroups
            .Select(group => new GanttGroup(group)
            {
                Items = ApplyItemUpdates(group.Items, updates)
            })
            .ToArray();

        return Task.CompletedTask;
    }

    private Task HandleTeachingPlanScheduleUpdated(GanttScheduleUpdate update)
    {
        var updates = update.CascadedUpdates
            .Append(update.PrimaryUpdate)
            .ToDictionary(item => item.ItemId, item => item.Item);

        TeachingPlanGroups = TeachingPlanGroups
            .Select(group => new GanttGroup(group)
            {
                Items = ApplyItemUpdates(group.Items, updates)
            })
            .ToArray();

        return Task.CompletedTask;
    }

    private static string ResolveItemid(GanttItem item) =>
        string.IsNullOrWhiteSpace(item.Id) ? item.Name : item.Id;

    private static IReadOnlyList<GanttItem> ApplyItemUpdates(
        IReadOnlyList<GanttItem> items,
        IReadOnlyDictionary<string, GanttItem> updates) =>
        items
            .Select(item =>
            {
                var nextItem = updates.TryGetValue(ResolveItemid(item), out var next) ? next : item;
                return item.Children is { Count: > 0 }
                    ? new GanttItem(nextItem) { Children = ApplyItemUpdates(item.Children, updates) }
                    : nextItem;
            })
            .ToArray();
