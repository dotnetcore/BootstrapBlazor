<Project>
  <PropertyGroup>
    <BootstrapBlazorGenerateAgentsMd Condition="'$(BootstrapBlazorGenerateAgentsMd)' == ''">true</BootstrapBlazorGenerateAgentsMd>
    <BootstrapBlazorAgentsTemplate>$(MSBuildThisFileDirectory)..\agents\BootstrapBlazor.AGENTS.md</BootstrapBlazorAgentsTemplate>
    <BootstrapBlazorAgentsDirectory Condition="'$(BootstrapBlazorAgentsDirectory)' == ''">$(MSBuildProjectDirectory)\.bootstrapblazor</BootstrapBlazorAgentsDirectory>
    <BootstrapBlazorAgentsTarget>$(BootstrapBlazorAgentsDirectory)\BootstrapBlazor.AGENTS.md</BootstrapBlazorAgentsTarget>
  </PropertyGroup>

  <Target Name="BootstrapBlazorGenerateAgentsMd"
          BeforeTargets="PrepareForBuild"
          Condition="'$(BootstrapBlazorGenerateAgentsMd)' == 'true' and Exists('$(BootstrapBlazorAgentsTemplate)')">
    <PropertyGroup>
      <_BootstrapBlazorHadAgentsMd Condition="Exists('$(BootstrapBlazorAgentsTarget)')">true</_BootstrapBlazorHadAgentsMd>
      <_BootstrapBlazorHadAgentsMd Condition="'$(_BootstrapBlazorHadAgentsMd)' == ''">false</_BootstrapBlazorHadAgentsMd>
    </PropertyGroup>

    <MakeDir Directories="$(BootstrapBlazorAgentsDirectory)"
             Condition="!Exists('$(BootstrapBlazorAgentsDirectory)')" />

    <Copy SourceFiles="$(BootstrapBlazorAgentsTemplate)"
          DestinationFiles="$(BootstrapBlazorAgentsTarget)"
          SkipUnchangedFiles="true"
          Condition="'$(_BootstrapBlazorHadAgentsMd)' == 'false'" />

    <Message Importance="high"
             Text="Generated BootstrapBlazor Agent rules: $(BootstrapBlazorAgentsTarget)"
             Condition="'$(_BootstrapBlazorHadAgentsMd)' == 'false'" />
  </Target>
</Project>
